#include <stdio.h>
#include "uart.h"
#include "gpio.h"
#include "gpio_exti.h"

static void exti_callback(void);

volatile uint8_t btn_pressed;

int main(void)
{
	uart_init();
	led_init();
	pc13_exti_init();

	while(1)
	{
		if(btn_pressed == 1)
		{
			exti_callback();
			for(volatile int i=0; i<100000; i++) ;
			btn_pressed = 0;
		}
	}
}

static void exti_callback(void)
{
	printf("BTN pressed...\r\n");
	led_toggle();
}

void EXTI15_10_IRQHandler(void)
{
	if((EXTI->PR & LINE13) != 0)
	{
		// clear PR flag
		EXTI->PR |= LINE13;

		btn_pressed = 1;
	}
}
