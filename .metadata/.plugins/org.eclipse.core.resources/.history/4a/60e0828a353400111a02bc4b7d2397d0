#include "gpio_exti.h"

#define GPIOCEN (1U<<2)
#define SYSCFGEN	(1U<<14)

void pc13_exti_init(void)
{
    __disable_irq();

    // 1. Clock
    RCC->AHB1ENR |= GPIOCEN;
    RCC->APB2ENR |= SYSCFGEN;

    // 2. GPIO Mode: Input
    GPIOC->MODER &= ~(3U << 26);

    // 3. PULL-DOWN: Fondamentale per pulsanti Attivo Alto
    GPIOC->PUPDR &= ~(3U << 26);
    GPIOC->PUPDR |=  (2U << 26); // 2U (ovvero 10 in binario) è Pull-down

    // 4. SYSCFG: Mappa EXTI13 su Port C
    SYSCFG->EXTICR[3] &= ~(0xFU << 4);
    SYSCFG->EXTICR[3] |=  (0x2U << 4);

    // 5. EXTI: Configura Rising Edge
    EXTI->IMR  |= LINE13;   // Unmask
    EXTI->FTSR &= ~LINE13;  // No Falling
    EXTI->RTSR |= LINE13;   // SI Rising (perché è Attivo Alto)

    // 6. NVIC: Pulisci flag vecchio e abilita
    EXTI->PR = LINE13;
    NVIC_EnableIRQ(EXTI15_10_IRQn);

    __enable_irq();
}
