void bmp280_init(void)
{
	uint8_t ctrl_meas = 0;
	uint8_t config = 0;

	ctrl_meas |= (1U<<2);		// pressure oversampling x1
	ctrl_meas |= (1U<<5);		// temperature oversampling x1
	// controls for the power mode are default to sleep (00). change it to 11 for normal mode after init

	config |= (1U<<5);			// sets 62.5 ms t_sb (standby)
	// zero filter coefficients, no 3-wire SPI
}

