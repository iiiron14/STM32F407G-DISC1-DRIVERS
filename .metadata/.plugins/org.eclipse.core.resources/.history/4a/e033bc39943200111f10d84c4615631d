void bmp280_read_calibration(BMP280_CALIB_COEFF_TypeDef *coeff)
{
	uint8_t data[24];

	bmp280_read(DIG_T1_REG_LSB, data, 24);		// lettura contigua di tutti i registri di calibrazione (speriamo funzioni)

	coeff->dig_T1 = (uint16_t) ( (data[1]<<8) | (data[0]) );
	coeff->dig_T2 = (int16_t) ( (data[3]<<8) | (data[2]) );
	coeff->dig_T3 = (int16_t) ( (data[5]<<8) | (data[4]) );
	coeff->dig_P1 = (uint16_t) ( (data[7]<<8) | (data[6]) );
	coeff->dig_P2 = (int16_t) ( (data[9]<<8) | (data[8]) );
	coeff->dig_P3 = (int16_t) ( (data[11]<<8) | (data[10]) );
	coeff->dig_P4 = (int16_t) ( (data[13]<<8) | (data[12]) );
	coeff->dig_P5 = (int16_t) ( (data[15]<<8) | (data[14]) );
	coeff->dig_P6 = (int16_t) ( (data[17]<<8) | (data[16]) );
	coeff->dig_P7 = (int16_t) ( (data[19]<<8) | (data[18]) );
	coeff->dig_P8 = (int16_t) ( (data[21]<<8) | (data[20]) );
	coeff->dig_P9 = (int16_t) ( (data[23]<<8) | (data[22]) );
}


int32_t t_fine;
/*Returns temperature in °C, resolution 0.01, output 5123 equals 51.23 °C*/
int32_t compensate_T_int32(int32_t adc_T, BMP280_CALIB_COEFF_TypeDef *coeff)
{
	int32_t var1, var2, T;
	var1 = ((((adc_T>>3) - ((int32_t)coeff->dig_T1<<1))) * ((int32_t)coeff->dig_T2)) >> 11;
	var2 = (((((adc_T>>4) - ((int32_t)coeff->dig_T1)) * ((adc_T>>4) - ((int32_t)coeff->dig_T1)))>>12) * ((int32_t)coeff->dig_T3)) >> 14;
	t_fine = var1 + var2;
	T = (t_fine*5 +128) >> 8;
	return T;
}

/*Returns pressure in Pa as unsigned 32 bit integer in Q24.8 format (24 integer bits and 8 fractional bits)
 * Output value of 24674867 represents 24674867/256 = 96386.2 Pa = 963.862 hPa*/
uint32_t compensate_P_int64(int32_t adc_P, BMP280_CALIB_COEFF_TypeDef *coeff)
{
	int64_t var1, var2, p;
	var1 = ((int64_t)t_fine) -128000;
	var2 = var1*var1*(int64_t)coeff->dig_P6;
	var2 = var2 + ((var1*(int64_t)coeff->dig_P5)<<17);
	var2 = var2 + (((int64_t)coeff->dig_P4)<<35);
	var1 = ((var1*var1*(int64_t)coeff->dig_P3)>>8) + ((var1*(int64_t)coeff->dig_P2)<<12);
	var1 = (((((int64_t)1)<<47)+var1))*((int64_t)coeff->dig_P1)>>33;
	if (var1==0)
		return 0;
	p = 1048576-adc_P;
	p=(((p<<31)-var2)*3125)/var1;
	var1 = (((int64_t)coeff->dig_P9)*(p>>13)*(p>>13)) >> 25;
	var2 = (((int64_t)coeff->dig_P8) * p) >> 19;
	p = ((p + var1 + var2) >> 8) + (((int64_t)coeff->dig_P7)<<4);
	return (uint32_t)p;
}

int32_t read_temp_raw(void)
{
	uint8_t data[2];
	int32_t T;

	bmp280_read(BMP280_REG_TEMP_MSB, data, 2);
	T = (int32_t) (((uint32_t)data[0]<<12) | ((uint32_t)data[1]<<4));	// deve essere allineata a sx su 20 bit

	return T;
}

uint32_t read_press_raw(void)
{
	uint8_t data[3];
	uint32_t P;

	bmp280_read(BMP280_REG_PRESS_MSB, data, 3);
	P = (uint32_t) (((uint32_t)data[0]<<12) | ((uint32_t)data[1]<<4) | ((uint32_t)data[2]>>4));

	return P;
}

void normal_mode_en(void)
{
	uint8_t ctrl_meas;

	bmp280_read(BMP280_REG_CTRL_MEAS, &ctrl_meas, 1);

	ctrl_meas |= (1U<<0);
	ctrl_meas |= (1U<<1);

	bmp280_write(BMP280_REG_CTRL_MEAS, ctrl_meas);
}










