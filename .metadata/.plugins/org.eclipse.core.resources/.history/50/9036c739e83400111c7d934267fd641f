void rtc_init(void)
{
	// enable clock access to PWR
	RCC->APB1ENR |= PWREN;

	// enable backup access to config RTC
	PWR->CR |= CR_DBP;

	// Enable low speed internal (LSI)
	RCC->CSR |= CSR_LSION;

	while((RCC->CSR & CSR_LSIRDY) != CSR_LSIRDY) ;

	// force backup domain reset
	RCC->BDCR |= BDCR_BDRST;
}



















