#include "gpio_exti.h"

#define GPIOCEN (1U<<2)
#define SYSCFGEN	(1U<<14)

void pc13_exti_init(void)
{
    __disable_irq();

    // 1. Abilita Clock per GPIOC e SYSCFG
    RCC->AHB1ENR |= (1U << 2);  // GPIOCEN
    RCC->APB2ENR |= (1U << 14); // SYSCFGEN

    // 2. PC13 come Input (00 nei bit 26-27)
    GPIOC->MODER &= ~(3U << 26);

    // 3. Pull-down (10 nei bit 26-27): tiene il pin a 0V
    GPIOC->PUPDR &= ~(3U << 26);
    GPIOC->PUPDR |=  (2U << 26);

    // 4. Mappa la linea 13 su PORT C (Importante!)
    SYSCFG->EXTICR[3] &= ~(0xFU << 4);
    SYSCFG->EXTICR[3] |=  (0x2U << 4);

    // 5. Configura EXTI
    EXTI->IMR  |= (1U << 13);    // Abilita linea 13
    EXTI->RTSR |= (1U << 13);    // Trigger su SALITA (perché attivo alto)
    EXTI->FTSR &= ~(1U << 13);   // Disabilita discesa

    // 6. Configura NVIC
    EXTI->PR = (1U << 13);       // Pulisci flag pendenti
    NVIC_SetPriority(EXTI15_10_IRQn, 0); // Priorità massima
    NVIC_EnableIRQ(EXTI15_10_IRQn);

    __enable_irq();
}
