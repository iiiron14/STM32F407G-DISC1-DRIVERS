#include "rtc.h"

#define PWREN				(1U<<28) // non verificato
#define CR_DBP				(1U<<8) // non verificato
#define CR_LSION			(1U<<0) // non verificato
#define CSR_LSIRDY			(1U<<1) // non verificato
#define BDCR_BDRST			(1U<<16) // non verificato
#define BDCR_RTCEN			(1U<<15) // non verificato

#define RTC_WRITE_PROTECTION_KEY_1	((uint8_t)0xCAU) // write in RTC_WPR
#define RTC_WRITE_PROTECTION_KEY_2	((uint8_t)0x53U) // write in RTC_WPR
#define RTC_INIT_MASK				(0xFFFFFFFFU) // non verificato
#define ISR_INITF					(1U<<6) // non verificato

#define WEEKDAY_FRIDAY		((uint8_t)0x05U) // non verificato
#define MONTH_APRIL			((uint8_t)0x04U) // non verificato
#define TIME_FORMAT_PM		(1U<<22) // non verificato
#define CR_FMT				(1U<<6) // non verificato
#define ISR_RSF				(1U<<5) // non verificato

#define RTC_ASYNCH_PREDIV		((uint32_t)0x7F) // non verificato
#define RTC_SYNCH_PREDIV		((uint32_t)0x00F9) // non verificato

static void rtc_set_asynch_prescaler(uint32_t AsynchPrescaler)
{
	MODIFY_REG(RTC->PRER, RTC_PRER_PREDIV_A, AsynchPrescaler << RTC_PRER_PREDIV_A_Pos);
}

static void rtc_set_synch_prescaler(uint32_t SynchPrescaler)
{
	MODIFY_REG(RTC->PRER, RTC_PRER_PREDIV_S, SynchPrescaler);
}


void _rtc_enable_init_mode(void)
{
	RTC->ISR = RTC_INIT_MASK;
}

void _rtc_disable_init_mode(void)
{
	RTC->ISR = ~RTC_INIT_MASK;
}


uint8_t _rtc_isActiveflag_init(void)
{
	return ((RTC->ISR & ISR_INITF) == ISR_INITF);
}

uint8_t _rtc_isActiveflag_rs(void)
{
	return ((RTC->ISR & ISR_RSF) == ISR_RSF);
}

static uint8_t rtc_init_seq(void)
{
	// start init mode
	_rtc_enable_init_mode();

	// wait until init mode is entered
	while(!(_rtc_isActiveflag_init)) ;

	return 1;
}

static uint8_t wait_for_synchro(void)
{
	// clear RSF
	RTC->ISR &= ~ISR_RSF;

	// wait for registers to synchronize
	while(!(_rtc_isActiveflag_rs)) ;

	return 1;
}

static uint8_t exit_init_seq(void)
{
	// stop init mode
	_rtc_disable_init_mode();

	// wait for registers to synchronize
	while(!wait_for_synchro()) ;
}



















