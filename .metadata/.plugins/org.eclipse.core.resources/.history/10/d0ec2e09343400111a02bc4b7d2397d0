#include <stdio.h>
#include "uart.h"
#include "gpio.h"
#include "gpio_exti.h"

int main(void)
{
	uart_init();
	led_init();
	pc13_exti_init();

	while(1) ;
}

static void exti_callback(void)
{
	printf("BTN pressed...\r\n");
	led_toggle();
}

void EXTI15_10_IRQHandler(void)
{
	if((EXTI->PR & LINE13) != 0)
	{
		// clear PR flag
		EXTI->PR |= LINE13;

		exti_callback();
	}
}
