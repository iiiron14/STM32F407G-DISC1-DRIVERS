#include "i2c.h"
#include "bmp280.h"
#include "uart.h"
#include <stdio.h>

// Variabili globali per i dati
BMP280_CALIB_COEFF_TypeDef coeff;
int32_t T_raw, T_comp;
uint32_t P_raw, P_comp;

int main(void)
{
    // 1. Inizializzazione periferiche
    uart_init();    // Per stampare su console PC
    i2c1_init();    // Inizializza PB8 e PB9

    printf("--- BMP280 I2C Test Start ---\r\n");

    // 2. Test di comunicazione rapido (Chip ID)
    uint8_t chip_id = 0;
    bmp280_read(0xD0, &chip_id, 1);

    if(chip_id == 0x58) {
        printf("Connessione I2C OK! Chip ID: 0x%02X\r\n", chip_id);
    } else {
        printf("Errore I2C! Chip ID letto: 0x%02X (Atteso: 0x58)\r\n", chip_id);
        printf("Controlla cablaggio SDA/SCL e alimentazione.\r\n");
        while(1); // Blocca qui se non comunica
    }

    // 3. Inizializzazione BMP280 (Configura Oversampling e Standby)
    bmp280_init();

    // 4. Lettura parametri di calibrazione (Fondamentale!)
    bmp280_read_calibration(&coeff);
    printf("Calibrazione caricata con successo.\r\n");

    // 5. Attivazione Normal Mode (Inizia a campionare)
    normal_mode_en();
    printf("Sensore in Normal Mode. Inizio letture...\r\n\n");

    while(1)
    {
        // 6. Lettura dati grezzi (Raw)
        T_raw = read_temp_raw();
        P_raw = read_press_raw();

        // 7. Compensazione (Trasformazione in valori reali)
        T_comp = compensate_T_int32(T_raw, &coeff);
        P_comp = compensate_P_int64(P_raw, &coeff);

        // 8. Stampa dei risultati
        // Temperatura: format %ld.%02ld (es: 25.40)
        printf("Temp: %ld.%02ld °C | ", T_comp / 100, T_comp % 100);

        // Pressione: format %lu.%02lu hPa (es: 1013.25)
        uint32_t press_Pa = P_comp / 256;
        printf("Pres: %lu.%02lu hPa\r\n", press_Pa / 100, press_Pa % 100);

        // Ritardo per la stabilità della lettura
        for(volatile int i = 0; i < 2000000; i++);
    }
}
